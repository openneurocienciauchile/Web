+  <nav class="nuro-cloud" aria-label="Áreas temáticas de investigación">
     {{ range $i, $page := .Pages }}
-    <li class="card nuro-tema-item">
-      <span class="nuro-tema-num" aria-hidden="true">
-        {{ printf "%02d" (add $i 1) }}
-      </span>
-      <div class="nuro-tema-body">
-        <h2 class="nuro-tema-title">
-          <a href="{{ $page.RelPermalink }}">{{ $page.Title }}</a>
-        </h2>
-        {{ with $page.Params.summary }}
-        <p class="nuro-tema-desc">{{ . }}</p>
-        {{ else }}
-        <p class="nuro-tema-desc">{{ $page.Summary }}</p>
+      {{ $slug := path.Base (strings.TrimSuffix "/" $page.RelPermalink) }}
+      {{ $count := len (where (where site.RegularPages "Section" "academicos") "Params.temas" "intersect" (slice $slug)) }}
+      {{ $size := printf "%.2f" (add 1.30 (mul (float $count) 0.13)) }}
+      {{ $cls := index (slice "nuro-cloud-a" "nuro-cloud-b" "nuro-cloud-c") (mod $i 3) }}
+      {{ $delay := printf "%.2f" (mul (float $i) 0.5) }}
+      {{ $dur := printf "%.2f" (add 6.5 (mul (float (mod $i 3)) 1.2)) }}
+      {{ $vo := mul (sub (int (mod $i 5)) 2) 14 }}
+      <a class="nuro-cloud-item" href="{{ $page.RelPermalink }}"
+         title="{{ $count }} académico{{ if ne $count 1 }}s{{ end }}"
+         style="animation-delay:{{ $delay }}s; animation-duration:{{ $dur }}s; margin-top:{{ $vo }}px;">
+        <span class="nuro-cloud-word {{ $cls }}" style="font-size:{{ $size }}rem;">{{ $page.Title }}</span>
+      </a>
+      {{ with $page.Params.tags }}
+        {{ range $j, $t := . }}
+          {{ $td := printf "%.2f" (add (mul (float $i) 0.5) (mul (float (add $j 1)) 0.35)) }}
+          {{ $tdur := printf "%.2f" (add 7.0 (mul (float (mod (add $i $j) 3)) 1.1)) }}
+          {{ $tvo := mul (sub (int (mod (add $i $j) 4)) 2) 9 }}
+          <span class="nuro-cloud-item nuro-cloud-tag"
+                style="animation-delay:{{ $td }}s; animation-duration:{{ $tdur }}s; margin-top:{{ $tvo }}px;">{{ $t }}</span>
         {{ end }}
-        <div class="nuro-tema-meta">
-          <a class="nuro-tema-link" href="{{ $page.RelPermalink }}">Ver más</a>
-          {{ with $page.Params.tags }}
-          <ul class="nuro-tema-tags" aria-label="Etiquetas">
-            {{ range . }}
-            <li class="nuro-tag">{{ . }}</li>
-            {{ end }}
-          </ul>
-          {{ end }}
-          {{ $slug := path.Base (strings.TrimSuffix "/" $page.RelPermalink) }}
-          {{ $acad := where (where site.RegularPages "Section" "academicos") "Params.temas" "intersect" (slice $slug) }}
-          {{ with len $acad }}
