+/* ── Encabezado ── */
+.nuro-temas-header{ margin-bottom:1.5rem; padding-bottom:1.25rem; border-bottom:1px solid rgba(0,0,0,.1); }
+.nuro-temas-title{ font-family:'Sora',sans-serif; font-size:2rem; font-weight:600; margin:0 0 .5rem; line-height:1.2; }
+.nuro-temas-subtitle{ font-size:1.05rem; color:#555; margin:0; line-height:1.6; }
+.nuro-temas-intro{ margin-top:.75rem; font-size:.95rem; color:#666; line-height:1.7; }
+
+/* ── Nube ── */
+.nuro-cloud{
+  position:relative; overflow:hidden; border-radius:20px;
+  background:radial-gradient(900px 520px at 76% 12%, #15275E 0%, #0A1230 58%, #080E22 100%);
+  padding:3.5rem 2rem; min-height:58vh;
+  display:flex; flex-wrap:wrap; align-items:center; justify-content:center;
+  gap:.3rem 1.7rem;
+}
+.nuro-cloud::after{
+  content:""; position:absolute; inset:0; pointer-events:none;
+  background:radial-gradient(560px 300px at 18% 82%, rgba(22,200,230,.12), transparent 60%);
+}
+.nuro-cloud-item{
+  position:relative; z-index:1; text-decoration:none; line-height:1;
+  animation:nuro-float 7s ease-in-out infinite; will-change:transform;
+}
+.nuro-cloud-word{
+  display:inline-block; font-family:'Sora',sans-serif; font-weight:600; letter-spacing:-.01em;
+  transition:transform .2s ease, color .2s ease, text-shadow .2s ease;
+}
+.nuro-cloud-a{ color:#FFFFFF; }
+.nuro-cloud-b{ color:#16C8E6; }
+.nuro-cloud-c{ color:#8FB6FF; }
+.nuro-cloud-item:hover .nuro-cloud-word{ transform:scale(1.12); color:#fff; text-shadow:0 6px 26px rgba(22,200,230,.55); }
+.nuro-cloud-tag{
+  font-family:'IBM Plex Sans',sans-serif; font-weight:400; font-size:.82rem;
+  color:rgba(255,255,255,.34); user-select:none;
+}
+.nuro-cloud-hint{ text-align:center; color:#8a93a8; font-size:.82rem; margin:1rem 0 0; }
+
+@keyframes nuro-float{ 0%,100%{ transform:translateY(0); } 50%{ transform:translateY(-12px); } }
+
+@media (prefers-reduced-motion: reduce){
+  .nuro-cloud-item{ animation:none !important; }
+}
+@media (max-width:600px){
+  .nuro-cloud{ padding:2.5rem 1rem; gap:.2rem 1.1rem; min-height:50vh; }
