-          <span class="nuro-tema-count">{{ . }} académico{{ if gt . 1 }}s{{ end }}</span>
-          {{ end }}
-          {{ end }}
-        </div>
-      </div>
-    </li>
+      {{ end }}
     {{ end }}
-  </ol>
+  </nav>
+  <p class="nuro-cloud-hint">El tamaño de cada área refleja cuántos académicos investigan en ella. Haz clic para explorarla.</p>
 
